<?xml version="1.0" encoding="UTF-8" ?>
<WMS_Capabilities version="<%= wmsVersion %>" xmlns="http://schemas.opengis.net/wms/1.3.0/capabilities_1_3_0.xsd"
xmlns:xlink="http://www.w3.org/1999/xlink" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.opengis.net/wms
    http://schemas.opengis.net/wms/<%= wmsVersion %>/capabilities_<%= wmsVersion.replaceAll(".", "_" ) %>.xsd">

    <Service>
        <Name>
            <%= workspace.id || "beacon-wms" %>
        </Name>
        <Title>
            <%= workspace.name || "Beacon WMS" %>
        </Title>
        <Abstract>
            <%= workspace.description || "" %>
        </Abstract>
    </Service>

    <Capability>
        <Request>
            <GetCapabilities>
                <Format>application/xml</Format>
                <DCPType>
                    <HTTP>
                        <Get>
                            <OnlineResource xlink:href="<%= baseUrl %>?" />
                        </Get>
                    </HTTP>
                </DCPType>
            </GetCapabilities>

            <GetMap>
                <Format>image/png</Format>
                <Format>image/jpeg</Format>
                <DCPType>
                    <HTTP>
                        <Get>
                            <OnlineResource xlink:href="<%= baseUrl %>?" />
                        </Get>
                    </HTTP>
                </DCPType>
            </GetMap>

            <GetFeatureInfo>
                <Format>text/plain</Format>
                <Format>application/json</Format>
                <DCPType>
                    <HTTP>
                        <Get>
                            <OnlineResource xlink:href="<%= baseUrl %>?" />
                        </Get>
                    </HTTP>
                </DCPType>
            </GetFeatureInfo>
        </Request>
        <Exception>
            <Format>XML</Format>
        </Exception>
        <Layer>
            <Title>
                <%= workspace.name || "Beacon WMS layers" %>
            </Title>
            <Abstract>
                <%= workspace.description || "" %>
            </Abstract>
            <CRS>EPSG:4326</CRS>
            <CRS>EPSG:3857</CRS>
            <CRS>EPSG:900913</CRS>
            <EX_GeographicBoundingBox>
                <westBoundLongitude>-180.0</westBoundLongitude>
                <eastBoundLongitude>180.0</eastBoundLongitude>
                <southBoundLatitude>-90.0</southBoundLatitude>
                <northBoundLatitude>90.0</northBoundLatitude>
            </EX_GeographicBoundingBox>
            <BoundingBox CRS="CRS:84" minx="-180.0" miny="-90.0" maxx="180.0" maxy="90.0" />
            <% workspace.layers.forEach(function(layer) { %>
            <Layer queryable="1" opaque="0" cascaded="0">
                <Name><%= layer.id %></Name>
                <Title><%= layer.name %></Title>
                <Abstract><%= layer.description || "" %></Abstract>
                <CRS>EPSG:4326</CRS>
                <CRS>EPSG:3857</CRS>
                <CRS>EPSG:900913</CRS>
                <EX_GeographicBoundingBox>
                    <westBoundLongitude>-180.0</westBoundLongitude>
                    <eastBoundLongitude>180.0</eastBoundLongitude>
                    <southBoundLatitude>-90.0</southBoundLatitude>
                    <northBoundLatitude>90.0</northBoundLatitude>
                </EX_GeographicBoundingBox>
                <BoundingBox CRS="CRS:84" minx="-180.0" miny="-90.0" maxx="180.0" maxy="90.0" />
            </Layer>
            <% }); %>
        </Layer>
    </Capability>
</WMS_Capabilities>